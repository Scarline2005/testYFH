PORT=3000
NODE_ENV=development

# SMTP config
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=your-smtp-user@your-domain.org
SMTP_PASS=your-app-password-or-smtp-secret
SMTP_FROM=Youth Foundation Haiti <no-reply@your-domain.org>
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_CONNECTION_TIMEOUT_MS=12000
SMTP_GREETING_TIMEOUT_MS=12000
SMTP_SOCKET_TIMEOUT_MS=20000

# Recipient mailbox
MAIL_TO=official-inbox@your-domain.org

# Optional CORS allow-list for frontend origins (comma-separated)
# Example: CLIENT_ORIGINS=https://www.your-domain.org,https://your-domain.org
CLIENT_ORIGINS=
