PORT=3000
NODE_ENV=development

# SendGrid API config
SENDGRID_API_KEY=SG.xxxxx
MAIL_FROM=contact@your-domain.org
MAIL_TO=official-inbox@your-domain.org
EXPECTED_SENDER_DOMAIN=your-domain.org

# Optional diagnostics protection token
DIAGNOSTIC_TOKEN=

# Optional DNS diagnostics
MAIL_DOMAIN=your-domain.org
DKIM_SELECTORS=default,mail,google
